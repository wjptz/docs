  "keyFeatures": [
    "Auto-injection of project specs into every AI coding session",
    "Three-phase workflow: Plan → Execute → Finish",
    "Cross-platform support for 16+ AI coding tools (Claude Code, Cursor, Codex, Kiro, Gemini CLI, etc.)",
    "Git-versioned spec library shared across the whole team",
    "Cross-session workspace memory via developer journals",
    "Auto-trigger skills for brainstorm, check, spec-update, and loop-break",
    "Custom spec templates via marketplace or private registry",
    "Task lifecycle management with PRD, design, and implementation artifacts",
    "Sub-agent roles for research, implementation, and verification",
    "Modular configuration via .trellis/config.yaml"
  ],
  "publicApiSurface": [
    "trellis init",
    "trellis init -u <name> --claude --cursor --codex ...",
    "trellis init --template <id>",
    "trellis init --registry <provider:repo/path>",
    "trellis upgrade",
    "trellis update",
